[
  {
    "id": "app-open",
    "description": "Launch or focus any macOS application by name",
    "examples": [
      "open Spotify",
      "launch Chrome",
      "open the browser",
      "switch to Premiere",
      "bring up OBS",
      "open Terminal",
      "focus Finder",
      "open Google Chrome"
    ],
    "primitive": "run_applescript",
    "template": "tell application \"{app}\" to activate"
  },
  {
    "id": "spotify-play-search",
    "description": "Search Spotify and start playing results",
    "examples": [
      "play some jazz",
      "put on Tchaikovsky",
      "throw on something chill",
      "play music",
      "search Spotify for lo-fi beats",
      "play some background music",
      "put on a song",
      "play {query} on Spotify"
    ],
    "required_apps": ["Spotify"],
    "primitive": "run_applescript",
    "template": "do shell script \"open 'spotify:search:{query}'\"\ntell application \"Spotify\" to play"
  },
  {
    "id": "spotify-pause",
    "description": "Pause or resume Spotify playback",
    "examples": [
      "pause the music",
      "stop Spotify",
      "pause",
      "resume music",
      "unpause",
      "play pause"
    ],
    "required_apps": ["Spotify"],
    "primitive": "run_applescript",
    "template": "tell application \"Spotify\" to playpause"
  },
  {
    "id": "web-search",
    "description": "Open the browser and search Google for a query",
    "examples": [
      "search for something online",
      "google it",
      "look that up",
      "what is machine learning",
      "find that online",
      "find florists in Wellington",
      "find me a plumber",
      "find restaurants near me",
      "find coffee shops in Auckland",
      "check the weather",
      "search the web",
      "open the Python docs",
      "look up the price of milk",
      "look that up in the browser"
    ],
    "primitive": "open_url",
    "template": "https://www.google.com/search?q={query}"
  },
  {
    "id": "click-link-safari",
    "description": "Click a search result link in Safari — first, second, or third organic Google result",
    "examples": [
      "click the first link",
      "open the first result",
      "click the top result",
      "open the first one",
      "click the second link",
      "open the second result",
      "click the third link",
      "open that first link"
    ],
    "primitive": "run_applescript",
    "template": "tell application \"Safari\"\n  activate\n  do JavaScript \"(function(){var ls=document.querySelectorAll('#rso a:has(h3),#search a:has(h3)');if(!ls.length)ls=document.querySelectorAll('a:has(h3)');var a=ls[{index}]||ls[0];if(a)window.location.href=a.href;})()\" in current tab of front window\nend tell"
  },
  {
    "id": "click-link-chrome",
    "description": "Click a search result link in Chrome or Arc — first, second, or third organic Google result",
    "examples": [
      "click the first link",
      "open the first result",
      "click the top result",
      "open the first one",
      "click the second link",
      "open the second result",
      "click the third link"
    ],
    "primitive": "run_applescript",
    "template": "tell application \"{browser}\" to tell active tab of front window to execute javascript \"(function(){var ls=document.querySelectorAll('#rso a:has(h3),#search a:has(h3)');if(!ls.length)ls=document.querySelectorAll('a:has(h3)');var a=ls[{index}]||ls[0];if(a)window.location.href=a.href;})()\""
  },
  {
    "id": "premiere-cut",
    "description": "Cut/razor at the playhead in Premiere Pro",
    "examples": [
      "cut here",
      "razor at playhead",
      "add edit",
      "cut the clip",
      "split here",
      "make a cut"
    ],
    "required_apps": ["Adobe Premiere Pro"],
    "primitive": "press_key",
    "template": { "combo": "cmd+k", "app": "Adobe Premiere Pro" }
  },
  {
    "id": "premiere-cut-all",
    "description": "Cut all tracks at the playhead in Premiere Pro",
    "examples": [
      "cut all tracks",
      "razor all tracks",
      "cut everything here",
      "split all tracks"
    ],
    "required_apps": ["Adobe Premiere Pro"],
    "primitive": "press_key",
    "template": { "combo": "cmd+shift+k", "app": "Adobe Premiere Pro" }
  },
  {
    "id": "premiere-play-pause",
    "description": "Toggle playback in Premiere Pro",
    "examples": [
      "play the timeline",
      "pause Premiere",
      "play pause in Premiere",
      "stop playback",
      "play from here"
    ],
    "required_apps": ["Adobe Premiere Pro"],
    "primitive": "press_key",
    "template": { "combo": "space", "app": "Adobe Premiere Pro" }
  },
  {
    "id": "premiere-step-back",
    "description": "Step the playhead back by frames in Premiere Pro",
    "examples": [
      "go back a frame",
      "step back",
      "one frame back",
      "go back {count} frames",
      "rewind a frame"
    ],
    "required_apps": ["Adobe Premiere Pro"],
    "primitive": "press_key",
    "template": {
      "combo": "left",
      "app": "Adobe Premiere Pro",
      "repeat": "{count}"
    }
  },
  {
    "id": "premiere-step-forward",
    "description": "Step the playhead forward by frames in Premiere Pro",
    "examples": [
      "go forward a frame",
      "step forward",
      "one frame forward",
      "go forward {count} frames",
      "next frame"
    ],
    "required_apps": ["Adobe Premiere Pro"],
    "primitive": "press_key",
    "template": {
      "combo": "right",
      "app": "Adobe Premiere Pro",
      "repeat": "{count}"
    }
  },
  {
    "id": "premiere-undo",
    "description": "Undo the last action in Premiere Pro",
    "examples": ["undo", "undo that", "go back", "undo the last cut"],
    "required_apps": ["Adobe Premiere Pro"],
    "primitive": "press_key",
    "template": { "combo": "cmd+z", "app": "Adobe Premiere Pro" }
  },
  {
    "id": "premiere-save",
    "description": "Save the Premiere Pro project",
    "examples": ["save the project", "save Premiere", "save my work"],
    "required_apps": ["Adobe Premiere Pro"],
    "primitive": "press_key",
    "template": { "combo": "cmd+s", "app": "Adobe Premiere Pro" }
  },
  {
    "id": "premiere-mark-in",
    "description": "Set the in-point marker at the playhead in Premiere Pro",
    "examples": ["mark in", "set in point", "mark the in point here"],
    "required_apps": ["Adobe Premiere Pro"],
    "primitive": "press_key",
    "template": { "combo": "i", "app": "Adobe Premiere Pro" }
  },
  {
    "id": "premiere-mark-out",
    "description": "Set the out-point marker at the playhead in Premiere Pro",
    "examples": ["mark out", "set out point", "mark the out point here"],
    "required_apps": ["Adobe Premiere Pro"],
    "primitive": "press_key",
    "template": { "combo": "o", "app": "Adobe Premiere Pro" }
  },
  {
    "id": "premiere-ripple-delete",
    "description": "Ripple delete the selected clip or in/out range in Premiere Pro",
    "examples": [
      "ripple delete",
      "delete and close gap",
      "remove and close gap",
      "ripple delete this"
    ],
    "required_apps": ["Adobe Premiere Pro"],
    "primitive": "press_key",
    "template": { "combo": "shift+delete", "app": "Adobe Premiere Pro" }
  },
  {
    "id": "obs-start-recording",
    "description": "Start recording in OBS",
    "examples": [
      "start recording",
      "begin recording",
      "start OBS",
      "record now",
      "hit record"
    ],
    "required_apps": ["OBS", "OBS Studio"],
    "primitive": "obs_call",
    "template": { "requestType": "StartRecord", "requestData": {} }
  },
  {
    "id": "obs-stop-recording",
    "description": "Stop recording in OBS",
    "examples": [
      "stop recording",
      "end recording",
      "stop OBS",
      "finish recording"
    ],
    "required_apps": ["OBS", "OBS Studio"],
    "primitive": "obs_call",
    "template": { "requestType": "StopRecord", "requestData": {} }
  },
  {
    "id": "obs-switch-scene",
    "description": "Switch OBS to a named scene",
    "examples": [
      "switch to {scene}",
      "change to {scene} scene",
      "OBS switch to {scene}",
      "show {scene}",
      "go to talking head",
      "switch to screen only"
    ],
    "required_apps": ["OBS", "OBS Studio"],
    "primitive": "obs_call",
    "template": {
      "requestType": "SetCurrentProgramScene",
      "requestData": { "sceneName": "{scene}" }
    }
  },
  {
    "id": "read-screen",
    "description": "Read the text currently visible on screen in an app",
    "examples": [
      "what does the screen say",
      "read the screen",
      "what's on screen",
      "read what's in Terminal",
      "what did Claude just say",
      "read that back to me"
    ],
    "primitive": "read_screen",
    "template": { "app": "{app}" }
  },
  {
    "id": "take-note",
    "description": "Save a note to Apple Notes",
    "examples": [
      "take a note",
      "note that {text}",
      "write this down",
      "remember this",
      "save a note saying {text}",
      "add a note"
    ],
    "primitive": "run_applescript",
    "template": "tell application \"Notes\"\n  activate\n  make new note with properties {body:\"{text}\"}\nend tell"
  },
  {
    "id": "terminal-run",
    "description": "Delegate a complex multi-step task to Claude Code (the AI coding agent) in Terminal",
    "examples": [
      "open a terminal and run {command}",
      "run {command} in terminal",
      "start a Claude Code session",
      "open terminal and ask Claude to {task}",
      "run claude in terminal",
      "hand this off to Claude Code",
      "delegate this to Claude",
      "have Claude write me a script to {task}",
      "ask Claude to refactor my code",
      "this is complex, let Claude handle it",
      "use Claude to {task}",
      "let Claude Code build {task}"
    ],
    "primitive": "run_applescript",
    "template": "tell application \"Terminal\"\n  activate\n  do script \"claude \\\"{task}\\\"\"\nend tell"
  }
]
